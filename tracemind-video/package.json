{
  "name": "tracemind-video",
  "version": "1.0.0",
  "private": true,
  "description": "Anthropic-style 72s product film for TraceMind · 研迹",
  "scripts": {
    "dev": "remotion studio src/Root.tsx",
    "build": "remotion render src/Root.tsx ProductFilm out/tracemind-mute.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p --concurrency=4 --props=\"{\\\"withSubtitles\\\":false,\\\"withVoice\\\":false,\\\"withMusic\\\":false}\"",
    "build:subtitled": "remotion render src/Root.tsx ProductFilm out/tracemind-cc.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p --concurrency=4 --props=\"{\\\"withSubtitles\\\":true,\\\"withVoice\\\":false,\\\"withMusic\\\":false}\"",
    "build:final": "remotion render src/Root.tsx ProductFilm out/tracemind-final.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p --concurrency=4 --props=\"{\\\"withSubtitles\\\":true,\\\"withVoice\\\":true,\\\"withMusic\\\":false}\"",
    "build:final-music": "remotion render src/Root.tsx ProductFilm out/tracemind-final-music.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p --concurrency=4 --props=\"{\\\"withSubtitles\\\":true,\\\"withVoice\\\":true,\\\"withMusic\\\":true}\"",
    "build:srt": "node scripts/build-srt.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.0"
  }
}
